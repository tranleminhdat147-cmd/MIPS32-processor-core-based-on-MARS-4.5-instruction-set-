module mip_datapath(
	clk,
	ZERO_EX,
	regwrite_WB,
	memtoreg_WB,
	Stall,
	Flush_idex,
	Flush_ifid,
	JUMP_ID,
	BRANCH_SEL,
	A_ALU_EX,
	Address_IF,
	alu_result_EX,
	alu_result_MEM,
	alu_result_WB,
	Aluop_EX,
	B_ALU_EX,
	dmem_data_MEM,
	dmem_data_WB,
	IMM_ID,
	instruct_ID,
	rd_REG_EX,
	rd_REG_MEM,
	rd_REG_WB,
	rs_data_ID,
	rs_ID,
	rt_data_ID,
	rt_ID
);


input wire	clk;
output wire	ZERO_EX;
output wire	regwrite_WB;
output wire	memtoreg_WB;
output wire	Stall;
output wire	Flush_idex;
output wire	Flush_ifid;
output wire	JUMP_ID;
output wire	BRANCH_SEL;
output wire	[31:0] A_ALU_EX;
output wire	[7:0] Address_IF;
output wire	[31:0] alu_result_EX;
output wire	[31:0] alu_result_MEM;
output wire	[31:0] alu_result_WB;
output wire	[2:0] Aluop_EX;
output wire	[31:0] B_ALU_EX;
output wire	[31:0] dmem_data_MEM;
output wire	[31:0] dmem_data_WB;
output wire	[31:0] IMM_ID;
output wire	[31:0] instruct_ID;
output wire	[4:0] rd_REG_EX;
output wire	[4:0] rd_REG_MEM;
output wire	[4:0] rd_REG_WB;
output wire	[31:0] rs_data_ID;
output wire	[4:0] rs_ID;
output wire	[31:0] rt_data_ID;
output wire	[4:0] rt_ID;

wire	[31:0] a_alu_ex_ALTERA_SYNTHESIZED;
wire	[31:0] alu_result_ex_ALTERA_SYNTHESIZED;
wire	[31:0] alu_result_mem_ALTERA_SYNTHESIZED;
wire	[31:0] alu_result_wb_ALTERA_SYNTHESIZED;
wire	[2:0] Aluop_ex_ALTERA_SYNTHESIZED;
wire	[2:0] Aluop_id;
wire	alusrc_ex;
wire	alusrc_id;
wire	[31:0] b_alu_ex_ALTERA_SYNTHESIZED;
wire	bne_ex;
wire	bne_id;
wire	bne_mem;
wire	branch_ex;
wire	branch_id;
wire	branch_mem;
wire	branch_sel_ALTERA_SYNTHESIZED;
wire	[31:0] dmem_data_mem_ALTERA_SYNTHESIZED;
wire	[31:0] dmem_data_wb_ALTERA_SYNTHESIZED;
wire	flush_idex_ALTERA_SYNTHESIZED;
wire	flush_ifid_ALTERA_SYNTHESIZED;
wire	[31:0] imm;
wire	[31:0] imm_id_ALTERA_SYNTHESIZED;
wire	[31:0] instr;
wire	jmp_id;
wire	memread_ex;
wire	memread_id;
wire	memread_mem;
wire	memtoreg_ex;
wire	memtoreg_id;
wire	memtoreg_mem;
wire	memtoreg_wb_ALTERA_SYNTHESIZED;
wire	memwrite_ex;
wire	memwrite_id;
wire	memwrite_mem;
wire	[31:0] out;
wire	[4:0] rd_REG_ex_ALTERA_SYNTHESIZED;
wire	[4:0] rd_REG_mem_ALTERA_SYNTHESIZED;
wire	[4:0] rd_REG_wb_ALTERA_SYNTHESIZED;
wire	regdst_ex;
wire	regdst_id;
wire	regwrite_ex;
wire	regwrite_id;
wire	regwrite_mem;
wire	regwrite_wb_ALTERA_SYNTHESIZED;
wire	[31:0] rs_data_id_ALTERA_SYNTHESIZED;
wire	[31:0] rt_data_id_ALTERA_SYNTHESIZED;
wire	Stall_ALTERA_SYNTHESIZED;
wire	uses_rs_id;
wire	uses_rt_id;
wire	zero_ex_ALTERA_SYNTHESIZED;
wire	zero_extend_id;
wire	[31:0] SYNTHESIZED_WIRE_0;
wire	[5:0] SYNTHESIZED_WIRE_1;
wire	[4:0] SYNTHESIZED_WIRE_2;
wire	[31:0] SYNTHESIZED_WIRE_3;
wire	[31:0] SYNTHESIZED_WIRE_24;
wire	[31:0] SYNTHESIZED_WIRE_5;
wire	[4:0] SYNTHESIZED_WIRE_7;
wire	[4:0] SYNTHESIZED_WIRE_8;
wire	SYNTHESIZED_WIRE_9;
wire	[31:0] SYNTHESIZED_WIRE_10;
wire	SYNTHESIZED_WIRE_11;
wire	[0:31] SYNTHESIZED_WIRE_12;
wire	[31:0] SYNTHESIZED_WIRE_25;
wire	[31:0] SYNTHESIZED_WIRE_14;
wire	[31:0] SYNTHESIZED_WIRE_26;
wire	[31:0] SYNTHESIZED_WIRE_18;
wire	[31:0] SYNTHESIZED_WIRE_19;
wire	[31:0] SYNTHESIZED_WIRE_20;
wire	[31:0] SYNTHESIZED_WIRE_21;
wire	[31:0] SYNTHESIZED_WIRE_22;
wire	[31:0] SYNTHESIZED_WIRE_23;

assign	SYNTHESIZED_WIRE_11 = 1;
assign	SYNTHESIZED_WIRE_12 = 0;




PC	b2v_inst(
	.clk(clk),
	.Stall(Stall_ALTERA_SYNTHESIZED),
	.in(SYNTHESIZED_WIRE_0),
	.out(out));


control_unit	b2v_inst1(
	.opcode(instr[31:26]),
	.regdst(regdst_id),
	.jmp(jmp_id),
	.branch(branch_id),
	.bne(bne_id),
	.memread(memread_id),
	.memtoreg(memtoreg_id),
	.memwrite(memwrite_id),
	.alusrc(alusrc_id),
	.regwrite(regwrite_id),
	.zero_extend(zero_extend_id),
	.uses_rs(uses_rs_id),
	.uses_rt(uses_rt_id),
	.aluop(Aluop_id));


alu	b2v_inst10(
	.a(a_alu_ex_ALTERA_SYNTHESIZED),
	.alu_control(SYNTHESIZED_WIRE_1),
	.b(b_alu_ex_ALTERA_SYNTHESIZED),
	.shamt(SYNTHESIZED_WIRE_2),
	.zero(zero_ex_ALTERA_SYNTHESIZED),
	.alu_result(alu_result_ex_ALTERA_SYNTHESIZED));


ex_mem	b2v_inst11(
	.branch_ex(branch_ex),
	.bne_ex(bne_ex),
	.memread_ex(memread_ex),
	.memtoreg_ex(memtoreg_ex),
	.memwrite_ex(memwrite_ex),
	.regwrite_ex(regwrite_ex),
	.zero_ex(zero_ex_ALTERA_SYNTHESIZED),
	.clk(clk),
	.alu_result_ex(alu_result_ex_ALTERA_SYNTHESIZED),
	.branch_offset_ex(SYNTHESIZED_WIRE_3),
	.rd_REG_ex(rd_REG_ex_ALTERA_SYNTHESIZED),
	.rt_REG_ex(SYNTHESIZED_WIRE_24),
	.branch_mem(branch_mem),
	.bne_mem(bne_mem),
	.memread_mem(memread_mem),
	.memtoreg_mem(memtoreg_mem),
	.memwrite_mem(memwrite_mem),
	.regwrite_mem(regwrite_mem),
	.zero_mem(SYNTHESIZED_WIRE_9),
	.alu_result_mem(alu_result_mem_ALTERA_SYNTHESIZED),
	.branch_offset_mem(SYNTHESIZED_WIRE_14),
	.rd_REG_mem(rd_REG_mem_ALTERA_SYNTHESIZED),
	.rt_REG_mem(SYNTHESIZED_WIRE_10));


id_ex	b2v_inst12(
	.regdst_id(regdst_id),
	.branch_id(branch_id),
	.bne_id(bne_id),
	.memread_id(memread_id),
	.memtoreg_id(memtoreg_id),
	.memwrite_id(memwrite_id),
	.alusrc_id(alusrc_id),
	.regwrite_id(regwrite_id),
	.Stall(Stall_ALTERA_SYNTHESIZED),
	.flush_IDEX(flush_idex_ALTERA_SYNTHESIZED),
	.clk(clk),
	.aluop_id(Aluop_id),
	.branch_offset_id(SYNTHESIZED_WIRE_5),
	.imm_id(imm_id_ALTERA_SYNTHESIZED),
	.rd_mux_id(instr[15:11]),
	.rs_REG_id(rs_data_id_ALTERA_SYNTHESIZED),
	.rt_mux_id(instr[20:16]),
	.rt_REG_id(rt_data_id_ALTERA_SYNTHESIZED),
	.shamt_id(instr[10:6]),
	.regdst_ex(regdst_ex),
	.branch_ex(branch_ex),
	.bne_ex(bne_ex),
	.memread_ex(memread_ex),
	.memtoreg_ex(memtoreg_ex),
	.memwrite_ex(memwrite_ex),
	.alusrc_ex(alusrc_ex),
	.regwrite_ex(regwrite_ex),
	.aluop_ex(Aluop_ex_ALTERA_SYNTHESIZED),
	.branch_offset_ex(SYNTHESIZED_WIRE_23),
	.imm_ex(imm),
	.rd_mux_ex(SYNTHESIZED_WIRE_8),
	.rs_REG_ex(a_alu_ex_ALTERA_SYNTHESIZED),
	.rt_mux_ex(SYNTHESIZED_WIRE_7),
	.rt_REG_ex(SYNTHESIZED_WIRE_24),
	.shamt_ex(SYNTHESIZED_WIRE_2));


alu_control	b2v_inst13(
	.alu_op(Aluop_ex_ALTERA_SYNTHESIZED),
	.funct(imm[5:0]),
	.alu_out(SYNTHESIZED_WIRE_1));


busmux_0	b2v_inst14(
	.sel(alusrc_ex),
	.dataa(SYNTHESIZED_WIRE_24),
	.datab(imm),
	.result(b_alu_ex_ALTERA_SYNTHESIZED));


busmux_1	b2v_inst15(
	.sel(regdst_ex),
	.dataa(SYNTHESIZED_WIRE_7),
	.datab(SYNTHESIZED_WIRE_8),
	.result(rd_REG_ex_ALTERA_SYNTHESIZED));


branch_selector	b2v_inst16(
	.branch_mem(branch_mem),
	.bne_mem(bne_mem),
	.zero_mem(SYNTHESIZED_WIRE_9),
	.branch_sel(branch_sel_ALTERA_SYNTHESIZED));



Data_Memory	b2v_inst20(
	.mem_write(memwrite_mem),
	.mem_read(memread_mem),
	.clk(clk),
	.address(alu_result_mem_ALTERA_SYNTHESIZED),
	.write_data(SYNTHESIZED_WIRE_10),
	.read_data(dmem_data_mem_ALTERA_SYNTHESIZED));
	defparam	b2v_inst20.MEM_SIZE = 256;


mem_wb	b2v_inst21(
	.memtoreg_mem(memtoreg_mem),
	.regwrite_mem(regwrite_mem),
	.clk(clk),
	.alu_result_mem(alu_result_mem_ALTERA_SYNTHESIZED),
	.dmem_data_mem(dmem_data_mem_ALTERA_SYNTHESIZED),
	.rd_REG_mem(rd_REG_mem_ALTERA_SYNTHESIZED),
	.memtoreg_wb(memtoreg_wb_ALTERA_SYNTHESIZED),
	.regwrite_wb(regwrite_wb_ALTERA_SYNTHESIZED),
	.alu_result_wb(alu_result_wb_ALTERA_SYNTHESIZED),
	.dmem_data_wb(dmem_data_wb_ALTERA_SYNTHESIZED),
	.rd_REG_wb(rd_REG_wb_ALTERA_SYNTHESIZED));


busmux_2	b2v_inst22(
	.sel(memtoreg_wb_ALTERA_SYNTHESIZED),
	.dataa(alu_result_wb_ALTERA_SYNTHESIZED),
	.datab(dmem_data_wb_ALTERA_SYNTHESIZED),
	.result(SYNTHESIZED_WIRE_20));


adder	b2v_inst25(
	.CIN(SYNTHESIZED_WIRE_11),
	.A(SYNTHESIZED_WIRE_12),
	.B(out),
	
	.SUM(SYNTHESIZED_WIRE_25));
	defparam	b2v_inst25.N = 32;


busmux_3	b2v_inst26(
	.sel(branch_sel_ALTERA_SYNTHESIZED),
	.dataa(SYNTHESIZED_WIRE_25),
	.datab(SYNTHESIZED_WIRE_14),
	.result(SYNTHESIZED_WIRE_18));


IMEM	b2v_inst27(
	.addr(out[7:0]),
	.q(SYNTHESIZED_WIRE_26));


if_id	b2v_inst29(
	.Stall(Stall_ALTERA_SYNTHESIZED),
	.flush_IFREG(flush_ifid_ALTERA_SYNTHESIZED),
	.clk(clk),
	.address_branch_IF(SYNTHESIZED_WIRE_25),
	.address_jump_IF(SYNTHESIZED_WIRE_26),
	.instr_IF(SYNTHESIZED_WIRE_26),
	.address_branch_ID(SYNTHESIZED_WIRE_5),
	.address_jump_ID(SYNTHESIZED_WIRE_19),
	.instr_ID(instr));


Sign_Extend	b2v_inst3(
	.in(instr[15:0]),
	.out(SYNTHESIZED_WIRE_21));


busmux_4	b2v_inst30(
	.sel(jmp_id),
	.dataa(SYNTHESIZED_WIRE_18),
	.datab(SYNTHESIZED_WIRE_19),
	.result(SYNTHESIZED_WIRE_0));


flush	b2v_inst31(
	.jump_id(jmp_id),
	.branch_sel(branch_sel_ALTERA_SYNTHESIZED),
	.flush_ifid(flush_ifid_ALTERA_SYNTHESIZED),
	.flush_idex(flush_idex_ALTERA_SYNTHESIZED));


Register_File	b2v_inst36(
	.ReadWrite(regwrite_wb_ALTERA_SYNTHESIZED),
	.clk(clk),
	.ReadAddress1(instr[25:21]),
	.ReadAddress2(instr[20:16]),
	.WriteAddress(rd_REG_wb_ALTERA_SYNTHESIZED),
	.WriteData(SYNTHESIZED_WIRE_20),
	.ReadData1(rs_data_id_ALTERA_SYNTHESIZED),
	.ReadData2(rt_data_id_ALTERA_SYNTHESIZED));


Sign_Extend	b2v_inst4(
	.in(instr[15:0]),
	.out(SYNTHESIZED_WIRE_22));


busmux_5	b2v_inst6(
	.sel(zero_extend_id),
	.dataa(SYNTHESIZED_WIRE_21),
	.datab(SYNTHESIZED_WIRE_22),
	.result(imm_id_ALTERA_SYNTHESIZED));


adder	b2v_inst7(
	
	.A(SYNTHESIZED_WIRE_23),
	.B(imm),
	
	.SUM(SYNTHESIZED_WIRE_3));
	defparam	b2v_inst7.N = 32;



Stall	b2v_inst9(
	.RegWrite_EX(regwrite_ex),
	.RegWrite_MEM(regwrite_mem),
	.uses_rs(uses_rs_id),
	.uses_rt(uses_rt_id),
	.rd_EX(rd_REG_ex_ALTERA_SYNTHESIZED),
	.rd_MEM(rd_REG_mem_ALTERA_SYNTHESIZED),
	.rs_ID(instr[25:21]),
	.rt_ID(instr[20:16]),
	.Stall(Stall_ALTERA_SYNTHESIZED));

assign	ZERO_EX = zero_ex_ALTERA_SYNTHESIZED;
assign	regwrite_WB = regwrite_wb_ALTERA_SYNTHESIZED;
assign	memtoreg_WB = memtoreg_wb_ALTERA_SYNTHESIZED;
assign	Stall = Stall_ALTERA_SYNTHESIZED;
assign	Flush_idex = flush_idex_ALTERA_SYNTHESIZED;
assign	Flush_ifid = flush_ifid_ALTERA_SYNTHESIZED;
assign	JUMP_ID = jmp_id;
assign	BRANCH_SEL = branch_sel_ALTERA_SYNTHESIZED;
assign	A_ALU_EX = a_alu_ex_ALTERA_SYNTHESIZED;
assign	Address_IF[7:0] = out[7:0];
assign	alu_result_EX = alu_result_ex_ALTERA_SYNTHESIZED;
assign	alu_result_MEM = alu_result_mem_ALTERA_SYNTHESIZED;
assign	alu_result_WB = alu_result_wb_ALTERA_SYNTHESIZED;
assign	Aluop_EX = Aluop_ex_ALTERA_SYNTHESIZED;
assign	B_ALU_EX = b_alu_ex_ALTERA_SYNTHESIZED;
assign	dmem_data_MEM = dmem_data_mem_ALTERA_SYNTHESIZED;
assign	dmem_data_WB = dmem_data_wb_ALTERA_SYNTHESIZED;
assign	IMM_ID = imm_id_ALTERA_SYNTHESIZED;
assign	instruct_ID = instr;
assign	rd_REG_EX = rd_REG_ex_ALTERA_SYNTHESIZED;
assign	rd_REG_MEM = rd_REG_mem_ALTERA_SYNTHESIZED;
assign	rd_REG_WB = rd_REG_wb_ALTERA_SYNTHESIZED;
assign	rs_data_ID = rs_data_id_ALTERA_SYNTHESIZED;
assign	rs_ID[4:0] = instr[25:21];
assign	rt_data_ID = rt_data_id_ALTERA_SYNTHESIZED;
assign	rt_ID[4:0] = instr[20:16];

endmodule

module busmux_0(sel,dataa,datab,result);
/* synthesis black_box */

input sel;
input [31:0] dataa;
input [31:0] datab;
output [31:0] result;

endmodule

module busmux_1(sel,dataa,datab,result);
/* synthesis black_box */

input sel;
input [4:0] dataa;
input [4:0] datab;
output [4:0] result;

endmodule

module busmux_2(sel,dataa,datab,result);
/* synthesis black_box */

input sel;
input [31:0] dataa;
input [31:0] datab;
output [31:0] result;

endmodule

module busmux_3(sel,dataa,datab,result);
/* synthesis black_box */

input sel;
input [31:0] dataa;
input [31:0] datab;
output [31:0] result;

endmodule

module busmux_4(sel,dataa,datab,result);
/* synthesis black_box */

input sel;
input [31:0] dataa;
input [31:0] datab;
output [31:0] result;

endmodule

module busmux_5(sel,dataa,datab,result);
/* synthesis black_box */

input sel;
input [31:0] dataa;
input [31:0] datab;
output [31:0] result;

endmodule
