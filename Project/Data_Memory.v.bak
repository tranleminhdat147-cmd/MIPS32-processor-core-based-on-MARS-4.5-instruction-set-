module Data_Memory (
    input clk,
    input [31:0] address,
    input [31:0] write_data,
    input mem_write,
    input mem_read,
    output reg [31:0] read_data
);
parameter MEM_SIZE = 256;
reg [31:0] memory [MEM_SIZE-1:0];  

always @(posedge clk) begin
    if (mem_write) begin
        memory[address[9:2]] <= write_data;
    end
    if (mem_read) begin
        read_data <= memory[address[9:2]];
    end
end


endmodule
